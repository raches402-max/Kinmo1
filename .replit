modules = ["nodejs-20", "web", "postgresql-16", "python-3.12"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 33145
externalPort = 8099

[[ports]]
localPort = 35035
externalPort = 5173

[[ports]]
localPort = 35037
externalPort = 8081

[[ports]]
localPort = 35447
externalPort = 8000

[[ports]]
localPort = 36795
externalPort = 3001

[[ports]]
localPort = 37053
externalPort = 3003

[[ports]]
localPort = 38749
externalPort = 3000

[[ports]]
localPort = 39257
externalPort = 8080

[[ports]]
localPort = 41329
externalPort = 5000

[[ports]]
localPort = 42389
externalPort = 4200

[[ports]]
localPort = 42637
externalPort = 6800

[[ports]]
localPort = 43953
externalPort = 3002

[[ports]]
localPort = 44413
externalPort = 6000

[[ports]]
localPort = 45873
externalPort = 9000

[[ports]]
localPort = 46589
externalPort = 8008

[env]
PORT = "3000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "chmod +x start-replit.sh && ./start-replit.sh"
waitForPort = 5000

[agent]
integrations = ["javascript_openai:1.0.0", "javascript_database:1.0.0", "javascript_log_in_with_replit:1.0.0"]
