# ==============================================
# Kinmo.ai Environment Variables Configuration
# ==============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ----------------------------------------------
# Database Configuration
# ----------------------------------------------
# PostgreSQL connection string (required)
# Example: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://username:password@localhost:5432/kinmo

# ----------------------------------------------
# External API Keys
# ----------------------------------------------
# OpenAI API key for AI-powered suggestions (required)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic API key for AI Event Assistant chat (required)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google Places API key (required)
# Get your key at: https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=AIza...

# Optional second Google Places API key for load balancing
GOOGLE_PLACES_API_KEY_2=AIza...

# Resend API key for email notifications (required)
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ----------------------------------------------
# Authentication (Replit Auth)
# ----------------------------------------------
# Session secret for cookie encryption (required, min 32 chars)
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-secret-key-min-32-characters-long-random-string

# Replit deployment domains (required)
# Example: https://your-app.replit.app
REPLIT_DOMAINS=https://your-app.replit.app

# Replit application ID (required)
REPL_ID=your-repl-id

# OpenID Connect issuer URL (optional)
# Default: https://replit.com/oidc
ISSUER_URL=https://replit.com/oidc

# ----------------------------------------------
# Server Configuration
# ----------------------------------------------
# Server port (optional)
# Default: 5000
PORT=5000

# Node environment (optional)
# Options: development, production, test
# Default: development
NODE_ENV=development

# ----------------------------------------------
# CORS and Frontend URLs
# ----------------------------------------------
# Comma-separated list of allowed CORS origins (optional)
# Example: https://kinmo.ai,https://www.kinmo.ai
ALLOWED_ORIGINS=http://localhost:5000

# Frontend URL for email links (optional)
# Falls back to REPLIT_DOMAINS or localhost
FRONTEND_URL=http://localhost:5000

# Replit dev domain (optional)
# Used for development environment links
REPLIT_DEV_DOMAIN=http://localhost:5000

# ----------------------------------------------
# Error Monitoring (Sentry)
# ----------------------------------------------
# Sentry DSN for error tracking (optional but recommended for production)
# Get your DSN at: https://sentry.io/settings/projects/YOUR_PROJECT/keys/
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# For client-side (Vite uses VITE_ prefix)
VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# Enable Sentry in development (optional)
# Set to 'true' to test Sentry locally
SENTRY_ENABLED=false
VITE_SENTRY_ENABLED=false

# ==============================================
# Security Notes
# ==============================================
# 1. Keep your .env file secure and never commit it
# 2. Use strong, randomly generated values for SESSION_SECRET
# 3. Rotate API keys regularly
# 4. Use environment-specific values for production
# 5. Enable 2FA on all external service accounts
