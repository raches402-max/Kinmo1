# Kinmo V2 Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ============================================================
# REQUIRED
# ============================================================

# PostgreSQL connection string. On Railway, auto-wired from the
# Postgres service via ${{Postgres.DATABASE_URL}}.
# For local dev, point at your local Postgres or a Neon free tier.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_random_64_char_hex_string_at_least_32_chars

# ============================================================
# GOOGLE OAUTH (required for login)
# ============================================================
# Get these from Google Cloud Console → APIs & Services → Credentials
# Authorized redirect URIs: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# OPTIONAL (features degrade gracefully without these)
# ============================================================

# OpenAI — for AI features (stubbed if missing)
OPENAI_API_KEY=

# Google Places — for venue search (stubbed if missing)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_API_KEY_2=

# Google Maps — for frontend map display
VITE_GOOGLE_MAPS_API_KEY=

# Email (Resend) — for notifications
RESEND_API_KEY=

# Error monitoring
SENTRY_DSN=
# Set to true to enable Sentry outside production once a DSN is configured
SENTRY_ENABLED=false

# ============================================================
# SERVER
# ============================================================
NODE_ENV=development
PORT=3000
# Set to false to skip reminder/automation schedulers in local or maintenance modes
ENABLE_BACKGROUND_JOBS=true

# ============================================================
# PRODUCTION (Railway)
# ============================================================
# Required for cron job endpoints in production. Generate with:
#   openssl rand -hex 32
CRON_SECRET=

# Comma-separated list of domains that should have a Google OAuth
# strategy registered. Example: kinmo-production.up.railway.app,kinmo.ai
CUSTOM_DOMAINS=

# Comma-separated list of email addresses with admin access. Used by the
# requireAdmin middleware (server/authorization.ts). If unset, no user has
# admin access — all admin endpoints return 403.
ADMIN_EMAILS=

# Override the base URL used for OG image links and shareable invite URLs.
# FRONTEND_URL takes precedence; falls back to BASE_URL, then to a hardcoded
# default (https://kinmo.ai in production, http://localhost:3000 in dev).
FRONTEND_URL=
BASE_URL=
