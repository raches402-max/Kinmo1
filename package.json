{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "dev:claude": "PORT=3000 NODE_ENV=development tsx server/index.ts",
    "server": "PORT=3000 NODE_ENV=development tsx server/index.ts",
    "client": "vite",
    "dev:replit": "./start-replit.sh",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "db:push": "drizzle-kit push",
    "backfill:itineraries": "tsx server/backfill-auto-event-itineraries.ts",
    "fix": "./fix-replit.sh",
    "fix:full": "./fix-replit.sh && npm install && npm run dev",
    "kill": "pkill -9 node; pkill -9 npm; pkill -9 tsx",
    "kill:port": "fuser -k 5000/tcp 2>/dev/null || true; fuser -k 3000/tcp 2>/dev/null || true",
    "clean": "rm -rf node_modules/.vite dist .vite client/dist"
  },
